{
  "name": "ims-pro",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "db:generate": "npx prisma generate --schema=packages/db/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema=packages/db/prisma/schema.prisma",
    "db:seed": "npx tsx packages/db/seed.ts",
    "setup": "npm install && npm run db:generate && npm run db:migrate && npm run db:seed",
    "electron:dev": "cd apps/desktop && npm run dev",
    "electron:install": "cd apps/desktop && npm install",
    "electron:build": "powershell -ExecutionPolicy Bypass -File apps/desktop/build.ps1"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": ">=18.0.0"
  }
}
