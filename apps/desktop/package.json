{
  "name": "@ims-pro/desktop",
  "version": "1.0.0",
  "description": "IMS-Pro نظام إدارة المخزون — تطبيق ويندوز",
  "author": "Etana",
  "main": "main.js",
  "scripts": {
    "dev":           "electron .",
    "build:win":     "electron-builder --win --x64",
    "build:portable":"electron-builder --win portable --x64",
    "build:dir":     "electron-builder --win --x64 --dir"
  },
  "build": {
    "appId":            "com.etana.imspro",
    "productName":      "IMS-Pro إيتانا",
    "copyright":        "Copyright © 2025 Etana",
    "electronVersion":  "31.7.7",
    "asar":             true,
    "directories": {
      "output":          "dist",
      "buildResources":  "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html"
    ],
    "extraResources": [
      {
        "from": "staging/api",
        "to":   "api",
        "filter": ["**/*"]
      },
      {
        "from": "staging/web",
        "to":   "web",
        "filter": ["**/*"]
      },
      {
        "from": "assets/seed.db",
        "to":   "seed.db"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick":                          false,
      "perMachine":                        false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":             true,
      "createStartMenuShortcut":           true
    }
  },
  "devDependencies": {
    "electron":         "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
