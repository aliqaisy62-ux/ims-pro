# ─── Database (Supabase / PostgreSQL) ────────────────────────────────────────
#
# Supabase gives you TWO connection strings — use BOTH:
#
#   DATABASE_URL  → Pooled connection (port 6543, PgBouncer)
#                   Used by the API at runtime (fast, supports many connections)
#
#   DIRECT_URL    → Direct connection (port 5432, no pooler)
#                   Used by Prisma migrations only (prisma migrate deploy)
#
# Where to find them in Supabase:
#   Project → Settings → Database → Connection string
#   Toggle "Display connection pooler" ON to see both URLs
#
# Format:
#   Pooled  : postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#   Direct  : postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT — change both before going live ──────────────────────────────────────
JWT_SECRET=ims-pro-jwt-secret-change-before-production-use-min-32-chars
JWT_REFRESH_SECRET=ims-pro-refresh-secret-change-before-production-use-min-32-chars

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4001
CORS_ORIGIN=http://localhost:3001

# ─── Exchange Rate (IQD per 1 USD) ────────────────────────────────────────────
EXCHANGE_RATE_IQD_USD=1480
