# ─── Database ─────────────────────────────────────────────────────────────────
#
# For Docker Compose deployments use the docker-compose.yml environment block.
# For Supabase, provide both connection strings:
#   DATABASE_URL  → Pooled connection (PgBouncer, port 6543) — used at runtime
#   DIRECT_URL    → Direct connection (port 5432) — used by Prisma migrations only
#
# Format:
#   Pooled  : postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#   Direct  : postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

DATABASE_URL=<REQUIRED>
DIRECT_URL=<REQUIRED>

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate unique secrets before deploying:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=<GENERATE_RANDOM_64_BYTES>
JWT_REFRESH_SECRET=<GENERATE_RANDOM_64_BYTES>

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4001

# ALLOWED_ORIGINS: comma-separated list of allowed frontend origins (REQUIRED in production).
# Example (LAN):    http://192.168.1.100
# Example (domain): https://your-domain.com
ALLOWED_ORIGINS=<REQUIRED>

# ─── Exchange Rate (IQD per 1 USD) ────────────────────────────────────────────
EXCHANGE_RATE_IQD_USD=1480

# ─── Seed ─────────────────────────────────────────────────────────────────────
SEED_DB=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=<REQUIRED_WHEN_SEED_DB_IS_TRUE>
