generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String    @id @default(cuid())
  name               String
  username           String    @unique
  passwordHash       String
  role               String    @default("CASHIER")
  language           String    @default("ar")
  isActive           Boolean   @default(true)
  tokenVersion       Int       @default(0)
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  mustChangePassword Boolean   @default(false)
  lastLoginAt        DateTime?
  passwordChangedAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  salesInvoices       SalesInvoice[]
  purchaseInvoices    PurchaseInvoice[]
  expenses            Expense[]
  stockTransfers      StockTransfer[]
  paymentVouchers     PaymentVoucher[]
  exchangeRateHistory ExchangeRateHistory[]
  auditLogs           AuditLog[]
  refreshSessions     RefreshSession[]

  @@index([username])
  @@index([isActive])
}

model Category {
  id      String @id @default(cuid())
  name_ar String
  name_en String

  items Item[]

  @@index([name_ar])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  balance   Decimal  @default(0)
  currency  String   @default("IQD")
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items            Item[]
  purchaseInvoices PurchaseInvoice[]

  @@index([name])
  @@index([isActive])
}

model Item {
  id             String    @id @default(cuid())
  barcode        String?   @unique
  name_ar        String
  name_en        String
  unit           String    @default("piece")
  categoryId     String?
  costPrice      Decimal   @default(0)
  retailPrice    Decimal   @default(0)
  wholesalePrice Decimal   @default(0)
  specialPrice   Decimal   @default(0)
  dollarPrice    Decimal   @default(0)
  dinarPrice     Decimal   @default(0)
  stockQty       Decimal   @default(0)
  minimumStock   Decimal   @default(0)
  expiryDate     DateTime?
  supplierId     String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  category          Category?             @relation(fields: [categoryId], references: [id])
  supplier          Supplier?             @relation(fields: [supplierId], references: [id])
  salesInvoiceItems SalesInvoiceItem[]
  purchaseItems     PurchaseInvoiceItem[]
  stockTransfers    StockTransfer[]

  @@index([barcode])
  @@index([categoryId])
  @@index([supplierId])
  @@index([isActive])
  @@index([stockQty])
  @@index([expiryDate])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  address     String?
  type        String   @default("RETAIL")
  creditLimit Decimal  @default(0)
  balance     Decimal  @default(0)
  currency    String   @default("IQD")
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesInvoices SalesInvoice[]

  @@index([name])
  @@index([phone])
  @@index([isActive])
  @@index([type])
}

model SalesInvoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  customerId    String?
  type          String   @default("CASH")
  priceType     String   @default("RETAIL")
  currency      String   @default("IQD")
  exchangeRate  Decimal  @default(1480)
  subtotal      Decimal  @default(0)
  discount      Decimal  @default(0)
  tax           Decimal  @default(0)
  total         Decimal  @default(0)
  amountPaid    Decimal  @default(0)
  balance       Decimal  @default(0)
  notes         String?
  createdById   String
  status        String   @default("DRAFT")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customer  Customer?          @relation(fields: [customerId], references: [id])
  createdBy User               @relation(fields: [createdById], references: [id])
  items     SalesInvoiceItem[]

  @@index([invoiceNumber])
  @@index([customerId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
  @@index([type])
}

model SalesInvoiceItem {
  id          String    @id @default(cuid())
  invoiceId   String
  itemId      String
  quantity    Decimal
  returnedQty Decimal   @default(0)
  unitPrice   Decimal
  currency    String    @default("IQD")
  subtotal    Decimal
  expiryDate  DateTime?

  invoice SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item         @relation(fields: [itemId], references: [id])

  @@index([invoiceId])
  @@index([itemId])
}

model PurchaseInvoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  supplierId    String
  currency      String   @default("IQD")
  exchangeRate  Decimal  @default(1480)
  subtotal      Decimal  @default(0)
  discount      Decimal  @default(0)
  total         Decimal  @default(0)
  amountPaid    Decimal  @default(0)
  balance       Decimal  @default(0)
  notes         String?
  createdById   String
  status        String   @default("DRAFT")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier  Supplier              @relation(fields: [supplierId], references: [id])
  createdBy User                  @relation(fields: [createdById], references: [id])
  items     PurchaseInvoiceItem[]

  @@index([invoiceNumber])
  @@index([supplierId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model PurchaseInvoiceItem {
  id         String    @id @default(cuid())
  invoiceId  String
  itemId     String
  quantity   Decimal
  unitCost   Decimal
  currency   String    @default("IQD")
  subtotal   Decimal
  expiryDate DateTime?

  invoice PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  item    Item            @relation(fields: [itemId], references: [id])

  @@index([invoiceId])
  @@index([itemId])
}

model ExpenseCategory {
  id      String @id @default(cuid())
  name_ar String
  name_en String

  expenses Expense[]

  @@index([name_ar])
}

model Expense {
  id           String   @id @default(cuid())
  categoryId   String
  description  String
  amount       Decimal
  currency     String   @default("IQD")
  exchangeRate Decimal  @default(1480)
  paidBy       String?
  date         DateTime @default(now())
  createdById  String
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category  ExpenseCategory @relation(fields: [categoryId], references: [id])
  createdBy User            @relation(fields: [createdById], references: [id])

  @@index([categoryId])
  @@index([date])
  @@index([createdById])
  @@index([isActive])
}

model StockTransfer {
  id          String   @id @default(cuid())
  type        String
  itemId      String
  quantity    Decimal
  reason      String
  createdById String
  notes       String?
  createdAt   DateTime @default(now())

  item      Item @relation(fields: [itemId], references: [id])
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([itemId])
  @@index([createdById])
  @@index([createdAt])
  @@index([type])
}

model PaymentVoucher {
  id            String   @id @default(cuid())
  voucherNumber String   @unique
  type          String
  entityType    String   @default("OTHER")
  entityId      String?
  amount        Decimal
  currency      String   @default("IQD")
  exchangeRate  Decimal  @default(1480)
  description   String
  createdById   String
  createdAt     DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([voucherNumber])
  @@index([type])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model CashStatement {
  id                String   @id @default(cuid())
  date              DateTime @unique
  openingBalanceUSD Decimal  @default(0)
  openingBalanceIQD Decimal  @default(0)
  cashSalesUSD      Decimal  @default(0)
  cashSalesIQD      Decimal  @default(0)
  creditSales       Decimal  @default(0)
  receipts          Decimal  @default(0)
  disbursements     Decimal  @default(0)
  expenses          Decimal  @default(0)
  closingBalanceUSD Decimal  @default(0)
  closingBalanceIQD Decimal  @default(0)
  isClosed          Boolean  @default(false)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([date])
  @@index([isClosed])
}

model ExchangeRateHistory {
  id          String   @id @default(cuid())
  rateIQD     Decimal
  changedById String
  createdAt   DateTime @default(now())

  changedBy User @relation(fields: [changedById], references: [id])

  @@index([createdAt])
}

model Settings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

model RefreshSession {
  id              String    @id @default(cuid())
  userId          String
  tokenHash       String    @unique
  familyId        String
  userAgent       String?
  ipAddress       String?
  createdAt       DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedReason   String?
  replacedByToken String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([familyId])
  @@index([expiresAt])
}
