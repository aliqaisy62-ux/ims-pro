{
  "name": "IMS-Pro",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",

  "features": {
    "ghcr.io/devcontainers/features/postgres:1": {
      "version": "15",
      "postgresUser": "${localEnv:DB_USER}",
      "postgresPassword": "${localEnv:DB_PASSWORD}",
      "postgresDb": "ims_pro"
    }
  },

  "forwardPorts": [3001, 4001, 5432],
  "portsAttributes": {
    "3001": { "label": "Web App", "onAutoForward": "openBrowser" },
    "4001": { "label": "API Server", "onAutoForward": "silent" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },

  "containerEnv": {
    "DATABASE_URL": "postgresql://${localEnv:DB_USER}:${localEnv:DB_PASSWORD}@localhost:5432/ims_pro",
    "NODE_ENV": "development",
    "PORT": "4001",
    "CORS_ORIGIN": "http://localhost:3001",
    "JWT_SECRET": "${localEnv:JWT_SECRET}",
    "JWT_REFRESH_SECRET": "${localEnv:JWT_REFRESH_SECRET}",
    "EXCHANGE_RATE_IQD_USD": "1480"
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "postStartCommand": "npm run dev",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "prisma.prisma",
        "bradlc.vscode-tailwindcss",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  }
}
