# ─── DATABASE ────────────────────────────────────────────────────────────────
# For Docker Compose: use container name 'postgres' as host, port 5432 (internal).
# For local dev (outside Docker): use localhost:5434.
DB_USER=imspro
DB_PASSWORD=***REMOVED***
DB_NAME=ims_pro
DATABASE_URL="postgresql://imspro:***REMOVED***@localhost:5434/ims_pro"
# DIRECT_URL is used by Prisma for migrations (same as DATABASE_URL for local Docker).
DIRECT_URL="postgresql://imspro:***REMOVED***@localhost:5434/ims_pro"

# ─── JWT SECRETS ─────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Or on Linux/macOS:
#   openssl rand -base64 64
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_HERE
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_64_CHAR_RANDOM_STRING_HERE

# ─── APPLICATION ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4001

# CORS_ORIGIN: comma-separated list of allowed origins.
# LAN deployment example: http://192.168.1.100
# Dev: http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ─── NEXT.JS ─────────────────────────────────────────────────────────────────
# URL the BROWSER uses to call the API.
# LAN production (via Nginx on port 80): http://SERVER_IP/api
# LAN dev (direct API):                  http://SERVER_IP:4001
# Local dev:                             http://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4001

# ─── BUSINESS DEFAULTS ───────────────────────────────────────────────────────
EXCHANGE_RATE_IQD_USD=1480

# ─── HTTPS ───────────────────────────────────────────────────────────────────
# Set to "true" ONLY when the app is served over HTTPS.
# When false (default), refresh-token cookie uses SameSite=Lax + no Secure flag,
# which works correctly on plain HTTP LAN deployments.
HTTPS_ENABLED=false

# ─── SEED ────────────────────────────────────────────────────────────────────
# Set to "true" on first run to seed the database with admin user + defaults.
# Set to "false" after first run to skip seeding on container restart.
SEED_DB=false

# ─── BACKUP ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
