# ─── DATABASE ────────────────────────────────────────────────────────────────
# For Docker Compose: use container name 'postgres' as host, port 5432 (internal).
# For local dev (outside Docker): use localhost:5434.
DB_USER=<REQUIRED>
DB_PASSWORD=<REQUIRED>
DB_NAME=ims_pro
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5434/ims_pro"
# DIRECT_URL is used by Prisma for migrations (same as DATABASE_URL for local Docker).
DIRECT_URL="postgresql://<DB_USER>:<DB_PASSWORD>@localhost:5434/ims_pro"

# ─── JWT SECRETS ─────────────────────────────────────────────────────────────
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
# Or on Linux/macOS:
#   openssl rand -base64 64
JWT_SECRET=<GENERATE_RANDOM_64_BYTES>
JWT_REFRESH_SECRET=<GENERATE_RANDOM_64_BYTES>

# ─── APPLICATION ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4001

# ALLOWED_ORIGINS: comma-separated list of allowed frontend origins (REQUIRED in production).
# Example (LAN):    http://192.168.1.100
# Example (domain): https://your-domain.com,https://www.your-domain.com
# In development this defaults to localhost:3000,localhost:3001 if unset.
ALLOWED_ORIGINS=<REQUIRED>

# ─── NEXT.JS ─────────────────────────────────────────────────────────────────
# URL the BROWSER uses to call the API.
# LAN production (via Nginx on port 80): leave empty (same-origin routing)
# LAN dev (direct API): http://SERVER_LAN_IP:PORT
NEXT_PUBLIC_API_URL=

# ─── SEED ────────────────────────────────────────────────────────────────────
# Set to "true" on first run to seed the database with admin user + defaults.
# SEED_ADMIN_PASSWORD must be set when SEED_DB=true — no default is provided.
SEED_DB=false
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=<REQUIRED_WHEN_SEED_DB_IS_TRUE>

# ─── BUSINESS DEFAULTS ───────────────────────────────────────────────────────
EXCHANGE_RATE_IQD_USD=1480

# ─── HTTPS ───────────────────────────────────────────────────────────────────
# Set to "true" ONLY when the app is served over HTTPS.
HTTPS_ENABLED=false

# ─── BACKUP ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
