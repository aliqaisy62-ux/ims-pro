# Database
DATABASE_URL="postgresql://imspro:***REMOVED***@localhost:5432/ims_pro"
DB_USER=imspro
DB_PASSWORD=***REMOVED***
DB_NAME=ims_pro

# JWT Secrets (generate with: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_min_64_chars_here_change_this_before_production
JWT_REFRESH_SECRET=your_refresh_secret_min_64_chars_here_change_this_before_production

# Application
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000

# Initial Exchange Rate (IQD per 1 USD)
EXCHANGE_RATE_IQD_USD=1480

# Backup settings
BACKUP_RETENTION_DAYS=30
