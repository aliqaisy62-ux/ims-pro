# ─── DATABASE ────────────────────────────────────────────────────────────────
# Railway: copy the DATABASE_URL from the PostgreSQL service → Variables tab
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/ims_pro"

# ─── JWT SECRETS ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET="GENERATE_A_64_CHAR_RANDOM_STRING_HERE"
JWT_REFRESH_SECRET="GENERATE_A_DIFFERENT_64_CHAR_RANDOM_STRING_HERE"

# ─── APPLICATION ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4001
# Set to your Railway web service public URL or custom domain
CORS_ORIGIN=https://YOUR_WEB_APP_URL

# ─── NEXT.JS (Web service only) ───────────────────────────────────────────────
# Set to your Railway API service public URL
NEXT_PUBLIC_API_URL=https://YOUR_API_SERVICE_URL

# ─── BUSINESS DEFAULTS ───────────────────────────────────────────────────────
# IQD per 1 USD
EXCHANGE_RATE_IQD_USD=1480

# ─── BACKUP ──────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
